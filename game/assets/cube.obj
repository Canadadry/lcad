# hand-authored 8-vertex cube, centered on origin, quad faces
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0

# UV per face corner (PRD 46): each of the 6 faces gets its own independent
# block of 4 vt entries mapping that face's corners (in the same order the
# face lists its vertices) onto the full (0,0)-(1,0)-(1,1)-(0,1) unit square
# — no vt entry is shared across faces, even where two faces share a 3D
# vertex, so every face renders undistorted and its UV points can be dragged
# independently of any other face's.
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

f 1/1 2/2 3/3 4/4
f 8/5 7/6 6/7 5/8
f 1/9 5/10 6/11 2/12
f 4/13 3/14 7/15 8/16
f 1/17 4/18 8/19 5/20
f 2/21 6/22 7/23 3/24
